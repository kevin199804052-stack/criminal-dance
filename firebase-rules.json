{
  "rules": {
    ".read": false,
    ".write": false,
    "rooms": {
      "$code": {
        ".read": "auth != null",
        ".write": "auth != null && ((!data.exists() && newData.child('host').val() === auth.uid) || (!newData.exists() && data.child('players').child(auth.uid).exists()))",
        "host": {
          ".write": "auth != null && newData.val() === auth.uid && (data.val() === auth.uid || !data.exists() || !data.parent().child('players').child(data.val()).exists())",
          ".validate": "newData.isString() && newData.parent().child('players').child(newData.val()).exists()"
        },
        "status": {
          ".write": "auth != null && ((newData.val() === 'playing' && newData.parent().child('host').val() === auth.uid) || (newData.val() === 'lobby' && (newData.parent().child('host').val() === auth.uid || data.parent().child('players').child(auth.uid).exists())))"
        },
        "winScore": {
          ".write": "auth != null && newData.parent().child('host').val() === auth.uid",
          ".validate": "newData.isNumber() && newData.val() >= 5 && newData.val() <= 10"
        },
        "createdAt": { ".write": "auth != null && newData.parent().child('host').val() === auth.uid" },
        "players": {
          "$pid": {
            ".write": "auth != null && ($pid === auth.uid || data.parent().parent().child('host').val() === auth.uid || newData.parent().parent().child('host').val() === auth.uid)",
            ".validate": "newData.child('name').isString() && newData.child('name').val().length <= 32 && !newData.child('name').val().matches(/[<>&\"'`]/)"
          }
        },
        "scores": {
          ".write": "auth != null && (data.parent().child('host').val() === auth.uid || newData.parent().child('host').val() === auth.uid)"
        },
        "public": { ".write": "auth != null && newData.parent().child('host').val() === auth.uid" },
        "actions": {
          "$id": {
            ".write": "auth != null && ((newData.exists() && newData.child('by').val() === auth.uid && root.child('rooms').child($code).child('players').child(auth.uid).exists()) || (!newData.exists() && root.child('rooms').child($code).child('host').val() === auth.uid))"
          }
        }
      }
    },
    "views": {
      "$code": {
        ".write": "auth != null && !newData.exists() && (!root.child('rooms').child($code).exists() || root.child('rooms').child($code).child('host').val() === auth.uid)",
        "$pid": {
          ".read": "auth != null && ($pid === auth.uid || root.child('rooms').child($code).child('host').val() === auth.uid)",
          ".write": "auth != null && root.child('rooms').child($code).child('host').val() === auth.uid"
        }
      }
    }
  }
}
